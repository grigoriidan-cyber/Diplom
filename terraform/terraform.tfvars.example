# Скопируйте этот файл в terraform.tfvars и подставьте свои значения.
# Реальный terraform.tfvars в git НЕ попадает (см. .gitignore).

cloud_id   = "b1gxxxxxxxxxxxxxxxxx" # yc config list  ->  cloud-id
folder_id  = "b1gxxxxxxxxxxxxxxxxx" # yc config list  ->  folder-id
trusted_ips = ["1.2.3.4", "5.6.7.8"] # белые IP, можно один или несколько: curl ifconfig.me

# Необязательные (значения по умолчанию подходят):
# sa_key_file         = "../key.json"
# ssh_public_key_path = "~/.ssh/id_rsa.pub"
# zone                = "ru-central1-a"
# preemptible         = true   # перед сдачей руководителю поставить false
